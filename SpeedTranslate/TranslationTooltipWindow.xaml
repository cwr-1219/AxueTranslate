<Window x:Class="SpeedTranslate.TranslationTooltipWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="翻译结果" 
        Height="Auto" 
        Width="350"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Deactivated="Window_Deactivated"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">
    
    <Window.Resources>
        <Storyboard x:Key="FadeInStory">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
        </Storyboard>
        <Storyboard x:Key="FadeOutStory">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.15"/>
        </Storyboard>

        <!-- ComboBoxItem 样式：实现暗色列表项的高级悬停及选中反馈 -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="1,1" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Name="ItemBorder" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#A855F7" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#6366F1" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox ToggleButton 样式：微调宽度和圆角 -->
        <Style x:Key="TooltipComboBoxToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Name="Border" 
                                Background="#1D1A2E" 
                                BorderBrush="#3D355C" 
                                BorderThickness="1" 
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="20" />
                                </Grid.ColumnDefinitions>
                                <!-- 右侧下拉小箭头 -->
                                <Path Grid.Column="1" 
                                      Data="M0,0 L3,3 L6,0" 
                                      Stroke="#94A3B8" 
                                      StrokeThickness="1.5" 
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#A855F7" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#A855F7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox 主样式：微型化适配弹窗 -->
        <Style x:Key="TooltipComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#1D1A2E" />
            <Setter Property="BorderBrush" Value="#3D355C" />
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="6,0,20,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- 触发按钮 -->
                            <ToggleButton Name="ToggleButton" 
                                           Style="{StaticResource TooltipComboBoxToggleButtonStyle}" 
                                           Focusable="False" 
                                           IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                           ClickMode="Press" />
                            
                            <!-- 当前选中项文本显示 -->
                            <ContentPresenter Name="ContentSite" 
                                               IsHitTestVisible="False" 
                                               Content="{TemplateBinding SelectionBoxItem}" 
                                               ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                               ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                               Margin="{TemplateBinding Padding}" 
                                               VerticalAlignment="Center" 
                                               HorizontalAlignment="Left" />
                            
                            <!-- 下拉弹窗 -->
                            <Popup Name="PART_Popup" 
                                   Placement="Bottom" 
                                   IsOpen="{TemplateBinding IsDropDownOpen}" 
                                   AllowsTransparency="True" 
                                   Focusable="False" 
                                   PopupAnimation="Slide">
                                <Grid Name="DropDown" 
                                      SnapsToDevicePixels="True" 
                                      MinWidth="{TemplateBinding ActualWidth}" 
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <!-- 圆角暗色下拉浮动卡片 -->
                                    <Border Name="DropDownBorder" 
                                            Background="#161224" 
                                            BorderBrush="#3D355C" 
                                            BorderThickness="1" 
                                            CornerRadius="6" 
                                            Margin="0,2,0,2">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000" BlurRadius="8" Opacity="0.5" ShadowDepth="1" />
                                        </Border.Effect>
                                        <ScrollViewer Margin="1" SnapsToDevicePixels="True" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" CanContentScroll="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="DropDownBorder" Property="Height" Value="95" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border x:Name="WindowBorder" 
            CornerRadius="10" 
            Background="#F20A0817" 
            BorderBrush="#3D355C" 
            BorderThickness="1.2" 
            Padding="14"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="12" Opacity="0.55" ShadowDepth="2" />
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <!-- 顶部信息栏 -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="译" Foreground="#A855F7" FontWeight="Bold" FontSize="11" Margin="0,0,6,0" />
                    <TextBlock x:Name="ModelTagText" Text="划词翻译 (AI)" Foreground="#64748B" FontSize="10" FontWeight="SemiBold" />
                </StackPanel>
                
                <!-- 微型关闭按钮 -->
                <Button Grid.Column="1" 
                        Content="✕" 
                        Click="CloseButton_Click"
                        Foreground="#475569"
                        FontSize="10"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="16"
                        Height="16"
                        VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bdr" Background="Transparent" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bdr" Property="Background" Value="#2A1B4E" />
                                    <Setter Property="Foreground" Value="#EF4444" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
            
            <!-- 翻译文本内容区 -->
            <ScrollViewer Grid.Row="1" MaxHeight="220" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                <StackPanel>
                    <!-- 原文 (可选显示) -->
                    <TextBlock x:Name="OriginalTextBlock" 
                               Text="" 
                               Foreground="#475569" 
                               FontSize="10" 
                               FontStyle="Italic"
                               TextWrapping="Wrap" 
                               Margin="0,0,0,6"
                               Visibility="Collapsed" />
                    
                    <!-- 译文 -->
                    <TextBlock x:Name="TranslatedTextBlock" 
                               Text="翻译中..." 
                               Foreground="#E2E8F0" 
                               FontSize="12" 
                               FontWeight="Normal"
                               LineHeight="18"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
            
            <!-- 底部操作按钮 -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="译为" Foreground="#94A3B8" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0" />
                    <ComboBox x:Name="LanguageComboBox" 
                              Width="95"
                              Height="22"
                              Style="{StaticResource TooltipComboBoxStyle}"
                              SelectionChanged="LanguageComboBox_SelectionChanged">
                        <ComboBoxItem Content="自动双向" Tag="Auto" />
                        <ComboBoxItem Content="英语" Tag="English" />
                        <ComboBoxItem Content="简体中文" Tag="Chinese" />
                        <ComboBoxItem Content="日语" Tag="Japanese" />
                        <ComboBoxItem Content="韩语" Tag="Korean" />
                        <ComboBoxItem Content="法语" Tag="French" />
                        <ComboBoxItem Content="德语" Tag="German" />
                        <ComboBoxItem Content="西班牙语" Tag="Spanish" />
                    </ComboBox>
                </StackPanel>

                <Button x:Name="CopyButton" 
                        Grid.Column="2"
                        HorizontalAlignment="Right"
                        Width="65"
                        Height="22"
                        Click="CopyButton_Click"
                        Foreground="#E2E8F0"
                        FontSize="9"
                        FontWeight="SemiBold"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bdr" CornerRadius="4" Background="#231F3A" BorderBrush="#3D355C" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bdr" Property="Background" Value="#A855F7" />
                                    <Setter TargetName="Bdr" Property="BorderBrush" Value="#A855F7" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋 复制" />
                        </StackPanel>
                    </Button.Content>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
