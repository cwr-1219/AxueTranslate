<Window x:Class="SpeedTranslate.TranslationTooltipWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="翻译结果" 
        Height="Auto" 
        Width="350"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Deactivated="Window_Deactivated"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">
    
    <Window.Resources>
        <Storyboard x:Key="FadeInStory">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
        </Storyboard>
        <Storyboard x:Key="FadeOutStory">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.15"/>
        </Storyboard>
    </Window.Resources>
    
    <Border x:Name="WindowBorder" 
            CornerRadius="10" 
            Background="#F20A0817" 
            BorderBrush="#3D355C" 
            BorderThickness="1.2" 
            Padding="14"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="12" Opacity="0.55" ShadowDepth="2" />
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <!-- 顶部信息栏 -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="译" Foreground="#A855F7" FontWeight="Bold" FontSize="11" Margin="0,0,6,0" />
                    <TextBlock x:Name="ModelTagText" Text="划词翻译 (AI)" Foreground="#64748B" FontSize="10" FontWeight="SemiBold" />
                </StackPanel>
                
                <!-- 微型关闭按钮 -->
                <Button Grid.Column="1" 
                        Content="✕" 
                        Click="CloseButton_Click"
                        Foreground="#475569"
                        FontSize="10"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="16"
                        Height="16"
                        VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bdr" Background="Transparent" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bdr" Property="Background" Value="#2A1B4E" />
                                    <Setter Property="Foreground" Value="#EF4444" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
            
            <!-- 翻译文本内容区 -->
            <ScrollViewer Grid.Row="1" MaxHeight="220" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                <StackPanel>
                    <!-- 原文 (可选显示) -->
                    <TextBlock x:Name="OriginalTextBlock" 
                               Text="" 
                               Foreground="#475569" 
                               FontSize="10" 
                               FontStyle="Italic"
                               TextWrapping="Wrap" 
                               Margin="0,0,0,6"
                               Visibility="Collapsed" />
                    
                    <!-- 译文 -->
                    <TextBlock x:Name="TranslatedTextBlock" 
                               Text="翻译中..." 
                               Foreground="#E2E8F0" 
                               FontSize="12" 
                               FontWeight="Normal"
                               LineHeight="18"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
            
            <!-- 底部操作按钮 -->
            <Grid Grid.Row="2">
                <Button x:Name="CopyButton" 
                        HorizontalAlignment="Right"
                        Width="65"
                        Height="22"
                        Click="CopyButton_Click"
                        Foreground="#E2E8F0"
                        FontSize="9"
                        FontWeight="SemiBold"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bdr" CornerRadius="4" Background="#231F3A" BorderBrush="#3D355C" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bdr" Property="Background" Value="#A855F7" />
                                    <Setter TargetName="Bdr" Property="BorderBrush" Value="#A855F7" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋 复制" />
                        </StackPanel>
                    </Button.Content>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
