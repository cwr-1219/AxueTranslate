<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SpeedTranslate.Linux.Views.TranslationTooltipWindow"
        Width="350"
        SizeToContent="Height"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None"
        ShowInTaskbar="False"
        ShowActivated="True"
        Topmost="True"
        CanResize="False"
        WindowStartupLocation="Manual"
        Deactivated="Window_Deactivated"
        KeyDown="Window_KeyDown">

    <Border Name="WindowBorder"
            Background="#E60A0817"
            BorderBrush="#3D355C"
            BorderThickness="1.2"
            CornerRadius="10"
            Padding="14"
            Margin="10"
            BoxShadow="0 4 20 0 #88000000">

        <Grid RowDefinitions="Auto,Auto,Auto">

            <!-- 顶部信息栏 -->
            <Grid Grid.Row="0" Margin="0,0,0,8" ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="译" Foreground="#A855F7" FontWeight="Bold" FontSize="11" Margin="0,0,6,0" />
                    <TextBlock Name="ModelTagText" Text="划词翻译 (AI)"
                               Foreground="#64748B" FontSize="10" FontWeight="SemiBold" />
                </StackPanel>
                <Button Grid.Column="1" Name="CloseBtn"
                        Content="✕"
                        Click="CloseButton_Click"
                        Foreground="#475569"
                        FontSize="10"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="18" Height="18"
                        VerticalAlignment="Center"
                        Padding="0"
                        Classes="TooltipClose" />
            </Grid>

            <!-- 翻译内容区 -->
            <ScrollViewer Grid.Row="1" MaxHeight="220"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,0,0,10">
                <StackPanel>
                    <!-- 原文（短文本时显示） -->
                    <TextBlock Name="OriginalTextBlock"
                               Foreground="#475569"
                               FontSize="10"
                               FontStyle="Italic"
                               TextWrapping="Wrap"
                               Margin="0,0,0,6"
                               IsVisible="False" />
                    <!-- 译文 -->
                    <TextBlock Name="TranslatedTextBlock"
                               Text="翻译中..."
                               Foreground="#E2E8F0"
                               FontSize="12"
                               TextWrapping="Wrap"
                               LineHeight="18" />
                </StackPanel>
            </ScrollViewer>

            <!-- 底部操作栏 -->
            <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto,8,Auto">
                <!-- 语种切换 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="译为" Foreground="#94A3B8" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,5,0" />
                    <ComboBox Name="LanguageComboBox"
                              Width="90" Height="22"
                              FontSize="10"
                              Classes="TooltipCombo"
                              SelectionChanged="LanguageComboBox_SelectionChanged">
                        <ComboBoxItem Content="自动双向" Tag="Auto" />
                        <ComboBoxItem Content="英语" Tag="English" />
                        <ComboBoxItem Content="简体中文" Tag="Chinese" />
                        <ComboBoxItem Content="日语" Tag="Japanese" />
                        <ComboBoxItem Content="韩语" Tag="Korean" />
                        <ComboBoxItem Content="法语" Tag="French" />
                        <ComboBoxItem Content="德语" Tag="German" />
                        <ComboBoxItem Content="西班牙语" Tag="Spanish" />
                    </ComboBox>
                </StackPanel>

                <!-- 复制按钮 -->
                <Button Grid.Column="2" Name="CopyBtn"
                        Content="📋 复制"
                        Click="CopyButton_Click"
                        Width="65" Height="22"
                        FontSize="9" FontWeight="SemiBold"
                        Classes="TooltipAction" />

                <!-- 替换按钮 -->
                <Button Grid.Column="4" Name="ReplaceBtn"
                        Content="⏎ 替换"
                        Click="ReplaceButton_Click"
                        Width="65" Height="22"
                        FontSize="9" FontWeight="SemiBold"
                        Classes="TooltipAction" />
            </Grid>

        </Grid>
    </Border>

    <Window.Styles>
        <Style Selector="Button.TooltipClose">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="Bdr" Background="Transparent" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.TooltipClose:pointerover /template/ Border#Bdr">
            <Setter Property="Background" Value="#2A1B4E" />
        </Style>
        <Style Selector="Button.TooltipClose:pointerover">
            <Setter Property="Foreground" Value="#EF4444" />
        </Style>

        <Style Selector="Button.TooltipAction">
            <Setter Property="Background" Value="#231F3A" />
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="BorderBrush" Value="#3D355C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.TooltipAction:pointerover">
            <Setter Property="Background" Value="#A855F7" />
            <Setter Property="BorderBrush" Value="#A855F7" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="ComboBox.TooltipCombo">
            <Setter Property="Background" Value="#1D1A2E" />
            <Setter Property="BorderBrush" Value="#3D355C" />
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="Padding" Value="6,0,4,0" />
        </Style>
        <Style Selector="ComboBox.TooltipCombo:pointerover">
            <Setter Property="BorderBrush" Value="#A855F7" />
        </Style>
        <Style Selector="ComboBox.TooltipCombo:focus">
            <Setter Property="BorderBrush" Value="#A855F7" />
        </Style>
    </Window.Styles>
</Window>
